# OpenRouter API Key（在 https://openrouter.ai/keys 申请）
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx

# 使用的模型，可在 OpenRouter 模型列表里挑
# 推荐：google/gemini-2.5-pro 或 deepseek/deepseek-chat
OPENROUTER_MODEL=google/gemini-2.5-pro

# 站点信息（OpenRouter 推荐传，便于查用量）
OPENROUTER_SITE_URL=https://trippick.vercel.app
OPENROUTER_SITE_NAME=TripPick
